{
  
  "homepage": "https://MeArmandP.github.io/devlog",
  
  "name": "my-app",
  
  "private": true,
  
  "version": "0.0.0",
  
  "type": "module",
  
  "scripts": {
  
    
  "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
  
    
  "dev:client": "vite --port 3000",
  
    
  "dev:server": "tsx watch server/index.ts",
  
    
  "build": "tsc -b && vite build",
  
    
  "build:server": "tsc -p server/tsconfig.server.json",
  
    
  "start": "node dist/index.js",
  
    
  "lint": "eslint .",
  
    
  "preview": "vite preview",
  
    
  "db:generate": "prisma generate",
  
    
  "db:push": "prisma db push",
  
    
  "predeploy": "npm run build",
  
    
  "deploy": "gh-pages -d dist",
  
    
  "db:studio": "prisma studio"
  
  },
  
  "dependencies": {
  
    
  "@prisma/adapter-mssql": "^7.6.0",
  
    
  "react": "^19.2.0",
  
    
  "react-dom": "^19.2.0",
  
    
  "react-router-dom": "^7.13.1"
  
  },
  
  "devDependencies": {
  
    
  "@eslint/js": "^9.39.1",
  
    
  "@prisma/client": "^7.6.0",
  
    
  "@types/cors": "^2.8.19",
  
    
  "@types/express": "^5.0.6",
  
    
  "@types/node": "^24.12.0",
  
    
  "@types/react": "^19.2.7",
  
    
  "@types/react-dom": "^19.2.3",
  
    
  "@vitejs/plugin-react": "^5.1.1",
  
    
  "concurrently": "^9.2.1",
  
    
  "cors": "^2.8.6",
  
    
  "dotenv": "^17.3.1",
  
    
  "eslint": "^9.39.1",
  
    
  "eslint-plugin-react-hooks": "^7.0.1",
  
    
  "eslint-plugin-react-refresh": "^0.4.24",
  
    
  "express": "^5.2.1",
  
    
  "gh-pages": "^6.3.0",
  
    
  "globals": "^16.5.0",
  
    
  "install": "^0.13.0",
  
    
  "isx": "^0.0.1",
  
    
  "npm": "^11.12.1",
  
    
  "prisma": "^7.6.0",
  
    
  "tsx": "^4.21.0",
  
    
  "typescript": "~5.9.3",
  
    
  "typescript-eslint": "^8.48.0",
  
    
  "vite": "^7.3.1"
  
  }
}
